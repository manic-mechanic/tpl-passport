# Controls dev-only UI (demo mode, location fence bypass toggle, QR scanner).
# Set to false in the Vercel production project environment variables.
# Defaults to true locally (no file needed for development).
NUXT_PUBLIC_IS_DEV=true

# Bypasses the geofence check during check-in — allows check-ins from any location.
# Use this for testers who need to test check-ins outside of branch locations.
# Defaults to false. Set to true in Vercel for tester deployments.
NUXT_PUBLIC_BYPASS_GEOFENCE=false

# BetterAuth — https://www.better-auth.com
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Set to your local dev URL or production domain
BETTER_AUTH_URL=https://localhost:3000

# Turso (libSQL) — https://turso.tech
# turso db show <db-name>  →  URL
# turso db tokens create <db-name>  →  auth token
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
# Redirect URI to register: https://<your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# PostHog — https://posthog.com
# Project API key found in Project Settings → Project API Key
NUXT_PUBLIC_POSTHOG_KEY=
# US region: https://us.i.posthog.com · EU region: https://eu.i.posthog.com
NUXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — https://sentry.io
# DSN found in Project Settings → Client Keys (DSN)
NUXT_PUBLIC_SENTRY_DSN=
# Auth token for source map uploads — Settings → Auth Tokens → create with Project: Read & Write
SENTRY_AUTH_TOKEN=
